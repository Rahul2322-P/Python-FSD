# Local PostgreSQL settings for the Django app
USE_POSTGRES=True
DB_NAME=ecolearn
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432

# Django settings
SECRET_KEY=your-secret-key
DEBUG=True
DEFAULT_FROM_EMAIL=no-reply@ecolearn.app
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
ADMIN_SECRET_CODE=HONEY
